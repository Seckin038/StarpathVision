{
  "name": "starpathvision-api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint .",
    "test": "jest",
    "migrate": "bash -c 'for f in migrations/*.sql; do echo Running $f; psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f \"$f\"; done'"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "multer": "^1.4.5",
    "ioredis": "^5.4.1",
    "bullmq": "^5.8.1",
    "pg": "^8.11.3",
    "nodemailer": "^6.9.13",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.2",
    "dotenv": "^16.4.5",
    "minio": "^8.0.1"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.11.30",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.12",
    "@eslint/js": "^8.57.0"
  }
}
